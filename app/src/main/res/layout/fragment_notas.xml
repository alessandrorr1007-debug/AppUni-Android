<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollNotas"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/rootNotas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtTituloNotas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mis Notas"
                    android:textColor="@color/text_primary"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtSubtituloNotas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Calificaciones sincronizadas desde UPAO"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnActualizarNotas"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@drawable/bg_day_selected"
                android:contentDescription="Actualizar notas"
                android:padding="12dp"
                android:src="@android:drawable/ic_popup_sync"
                android:tint="@color/white" />

        </LinearLayout>

        <!-- Tarjeta de resumen general KPI -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResumenNotas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/bg_dark_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Fila de métricas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Promedio General -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_icon_soft_purple"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊"
                            android:textSize="22sp" />

                        <TextView
                            android:id="@+id/txtPromedioGeneralNotas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="--"
                            android:textColor="@color/accent_purple_light"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Promedio"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Cursos -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_icon_soft_pink"
                        android:orientation="vertical"
                        android:padding="14dp"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📚"
                            android:textSize="22sp" />

                        <TextView
                            android:id="@+id/txtCursosRegistrados"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="--"
                            android:textColor="@color/accent_blue_light"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Cursos"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/txtEstadoGeneralNotas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Cargando última actualización..."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Lista de cursos (se llena dinámicamente) -->
        <LinearLayout
            android:id="@+id/seccionCursos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/contenedorCursos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

        <!-- Detalle de curso seleccionado -->
        <LinearLayout
            android:id="@+id/seccionDetalleCurso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:visibility="gone">

            <Button
                android:id="@+id/btnVolverCursos"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:backgroundTint="@color/accent_indigo"
                android:text="← Volver"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtCursoSeleccionado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Curso"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDescripcionCurso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Notas reales sincronizadas desde UPAO PX."
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <!-- Tarjeta de evaluaciones -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="@color/bg_dark_card"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Evaluaciones"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="EP1 20% · Parcial 30% · EP2 20% · Final 30%"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <!-- Fila EP1 + Parcial -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/edtEp1Curso"
                            android:layout_width="0dp"
                            android:layout_height="58dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input_premium"
                            android:gravity="center"
                            android:hint="EP1"
                            android:inputType="numberDecimal"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_muted"
                            android:textSize="16sp" />

                        <EditText
                            android:id="@+id/edtParcialCurso"
                            android:layout_width="0dp"
                            android:layout_height="58dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input_premium"
                            android:gravity="center"
                            android:hint="Parcial"
                            android:inputType="numberDecimal"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_muted"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- Fila EP2 + Final -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/edtEp2Curso"
                            android:layout_width="0dp"
                            android:layout_height="58dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input_premium"
                            android:gravity="center"
                            android:hint="EP2"
                            android:inputType="numberDecimal"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_muted"
                            android:textSize="16sp" />

                        <EditText
                            android:id="@+id/edtFinalCurso"
                            android:layout_width="0dp"
                            android:layout_height="58dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input_premium"
                            android:gravity="center"
                            android:hint="Final"
                            android:inputType="numberDecimal"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_muted"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtGuardarAutomatico"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="✓ Notas sincronizadas desde UPAO PX"
                        android:textColor="@color/ok_green"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <!-- Panel de resultado -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_resultado_premium"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:id="@+id/txtPromedioCurso"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Promedio actual: 0,00"
                            android:textColor="@color/text_primary"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <ProgressBar
                            android:id="@+id/progresoCurso"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="12dp"
                            android:max="2000"
                            android:progress="0"
                            android:progressTint="@color/accent_purple"
                            android:progressBackgroundTint="@color/border" />

                        <TextView
                            android:id="@+id/txtFinalNecesarioCurso"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Final necesario: completa EP1, Parcial y EP2"
                            android:textColor="@color/accent_blue_light"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtEstadoCurso"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Subcomponentes aparecerán aquí."
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
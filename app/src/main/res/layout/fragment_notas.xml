<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollNotas"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/rootNotas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtTituloNotas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mis Notas"
                    android:textColor="@color/text_primary"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtSubtituloNotas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Calificaciones desde UPAO"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnActualizarNotas"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@drawable/bg_day_selected"
                android:contentDescription="Actualizar notas"
                android:padding="12dp"
                android:src="@android:drawable/ic_popup_sync"
                android:tint="@color/white" />

        </LinearLayout>

        <!-- ProgressBar de carga -->
        <ProgressBar
            android:id="@+id/progressBarNotas"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="12dp"
            android:indeterminate="true"
            android:progressTint="@color/accent_purple"
            android:visibility="gone" />

        <!-- Tarjeta KPI general -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResumenNotas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/bg_dark_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Fila de métricas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Promedio General -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_icon_soft_purple"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊"
                            android:textSize="22sp" />

                        <TextView
                            android:id="@+id/txtPromedioGeneralNotas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="--"
                            android:textColor="@color/accent_purple_light"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Promedio"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Cursos registrados -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_icon_soft_pink"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📚"
                            android:textSize="22sp" />

                        <TextView
                            android:id="@+id/txtCursosRegistrados"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="--"
                            android:textColor="@color/accent_blue_light"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Cursos"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Estado / Última actualización -->
                <TextView
                    android:id="@+id/txtEstadoGeneralNotas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Cargando..."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ============================================================
             SECCIÓN: Lista de Cursos
             ============================================================ -->
        <LinearLayout
            android:id="@+id/seccionCursos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/contenedorCursos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

        <!-- ============================================================
             SECCIÓN: Detalle de Curso Seleccionado
             ============================================================ -->
        <LinearLayout
            android:id="@+id/seccionDetalleCurso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Botón volver -->
            <Button
                android:id="@+id/btnVolverCursos"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:backgroundTint="@color/accent_indigo"
                android:text="← Volver"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Nombre del curso -->
            <TextView
                android:id="@+id/txtCursoSeleccionado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Curso"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- Metadatos: NRC, créditos -->
            <TextView
                android:id="@+id/txtDescripcionCurso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <!-- KPI promedio del curso -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_result_premium"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/txtPromedioCurso"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Promedio: --"
                    android:textColor="@color/text_primary"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progresoCurso"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="10dp"
                    android:max="2000"
                    android:progress="0"
                    android:progressTint="@color/accent_purple"
                    android:progressBackgroundTint="@color/border" />

                <TextView
                    android:id="@+id/txtFinalNecesarioCurso"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text=""
                    android:textColor="@color/accent_blue_light"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Contenedor dinámico de componentes (EP1/Parcial/EP2/Final) -->
            <LinearLayout
                android:id="@+id/contenedorComponentes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/contenedorInicio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Encabezado -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UPAO PX 🎓"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary" />

        <TextView
            android:id="@+id/txtSemana"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Semana académica"
            android:textSize="14sp"
            android:textColor="@color/color_primary"
            android:layout_marginTop="2dp" />

        <!-- Sección Resumen -->
        <LinearLayout
            android:id="@+id/seccionResumen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="22dp">

            <!-- Tarjeta: Clases de hoy -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/color_card_bg"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_soft_purple">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📚"
                            android:textSize="28sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtClasesHoy"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Horario de hoy\n3 clases programadas"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_text_primary"
                        android:layout_marginStart="16dp" />

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="›"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_primary"
                        android:gravity="center" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tarjeta: Calculadora (fondo violeta) -->
            <LinearLayout
                android:id="@+id/txtAbrirCalculadora"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_day_selected"
                android:padding="18dp"
                android:layout_marginTop="14dp">

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:gravity="center"
                    android:background="@drawable/bg_result_premium">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🧮"
                        android:textSize="28sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calculadora"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_text_on_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Promedio académico"
                        android:textSize="14sp"
                        android:textColor="@color/color_text_on_primary"
                        android:alpha="0.8"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="↗"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_on_primary"
                    android:gravity="center" />
            </LinearLayout>

        </LinearLayout>

        <!-- Sección Calculadora Detalle -->
        <LinearLayout
            android:id="@+id/seccionCalculadora"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="22dp">

            <Button
                android:id="@+id/btnVolverInicio"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="← Volver"
                android:textStyle="bold"
                android:textColor="@color/color_on_primary"
                android:backgroundTint="@color/color_primary"
                android:textAllCaps="false" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Calculadora"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:layout_marginTop="18dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Calcula tu promedio y la nota que necesitas."
                android:textSize="14sp"
                android:textColor="@color/color_text_secondary"
                android:layout_marginTop="4dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/color_card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Evaluaciones"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_text_primary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="EP1 20% · Parcial 30% · EP2 20% · Final 30%"
                        android:textSize="13sp"
                        android:textColor="@color/color_text_secondary"
                        android:layout_marginTop="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">

                        <EditText
                            android:id="@+id/edtEp1"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:hint="EP1"
                            android:inputType="numberDecimal"
                            android:textSize="16sp"
                            android:gravity="center"
                            android:singleLine="true"
                            android:textColor="@color/color_text_primary"
                            android:textColorHint="@color/color_text_muted"
                            android:background="@drawable/bg_input_premium" />

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <EditText
                            android:id="@+id/edtParcial"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:hint="Parcial"
                            android:inputType="numberDecimal"
                            android:textSize="16sp"
                            android:gravity="center"
                            android:singleLine="true"
                            android:textColor="@color/color_text_primary"
                            android:textColorHint="@color/color_text_muted"
                            android:background="@drawable/bg_input_premium" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp">

                        <EditText
                            android:id="@+id/edtEp2"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:hint="EP2"
                            android:inputType="numberDecimal"
                            android:textSize="16sp"
                            android:gravity="center"
                            android:singleLine="true"
                            android:textColor="@color/color_text_primary"
                            android:textColorHint="@color/color_text_muted"
                            android:background="@drawable/bg_input_premium" />

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <EditText
                            android:id="@+id/edtFinal"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:hint="Final"
                            android:inputType="numberDecimal"
                            android:textSize="16sp"
                            android:gravity="center"
                            android:singleLine="true"
                            android:textColor="@color/color_text_primary"
                            android:textColorHint="@color/color_text_muted"
                            android:background="@drawable/bg_input_premium" />
                    </LinearLayout>

                    <!-- Panel resultado -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_result_premium"
                        android:padding="18dp"
                        android:layout_marginTop="18dp">

                        <TextView
                            android:id="@+id/txtPromedio"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Promedio actual: 0,00"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_text_primary" />

                        <TextView
                            android:id="@+id/txtNotaNecesaria"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Final necesario: completa EP1, Parcial y EP2"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_tertiary"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:id="@+id/txtEstado"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Ingresa tus notas para calcular automáticamente."
                            android:textSize="13sp"
                            android:textColor="@color/color_text_secondary"
                            android:layout_marginTop="6dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Sección: Configuración de Tema -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Configuración"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:layout_marginTop="32dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/color_card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tema de la aplicación"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Selecciona el modo de visualización"
                    android:textSize="13sp"
                    android:textColor="@color/color_text_secondary"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnThemeLight"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="☀ Claro"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:layout_marginEnd="6dp"
                        app:cornerRadius="12dp"
                        app:strokeColor="@color/color_border" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnThemeDark"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="🌙 Oscuro"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        app:cornerRadius="12dp"
                        app:strokeColor="@color/color_border" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnThemeSystem"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="⚙ Sistema"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:layout_marginStart="6dp"
                        app:cornerRadius="12dp"
                        app:strokeColor="@color/color_border" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Nav item inactivo: texto muted, sin fondo -->
    <style name="NavItem">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">6dp</item>
    </style>

    <!-- Nav item activo: fondo violeta pill -->
    <style name="NavItemActive">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1.25</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_nav_active</item>
        <item name="android:padding">6dp</item>
    </style>

    <!-- Texto nav inactivo -->
    <style name="NavText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#64748B</item>
        <item name="android:layout_marginTop">2dp</item>
    </style>

    <!-- Texto nav activo (blanco sobre fondo violeta) -->
    <style name="NavTextActive">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:layout_marginTop">2dp</item>
    </style>

</resources>
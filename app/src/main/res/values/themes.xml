<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Tema base oscuro (Material3 Dark - atributos correctos) -->
    <style name="Base.Theme.AgendaPx" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Colores primarios M3 correctos -->
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorPrimaryContainer">@color/accent_indigo</item>
        <item name="colorSecondary">@color/accent_blue</item>
        <item name="colorSecondaryContainer">@color/bg_surface</item>

        <!-- Superficies -->
        <item name="colorSurface">@color/bg_dark_card</item>
        <item name="colorSurfaceVariant">@color/bg_surface</item>

        <!-- Fondo del sistema (atributo Android correcto, NO colorBackground sin prefijo) -->
        <item name="android:colorBackground">@color/bg_dark</item>

        <!-- Texto sobre colores -->
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Barra de estado y navegación -->
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Theme.AgendaPx" parent="Base.Theme.AgendaPx" />

</resources>